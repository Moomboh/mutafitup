        "results/data_stats/comparison/dashboard.html",
        "results/data_stats/duplicates/resplit/dashboard.html",
        "results/data_stats/duplicates/original/dashboard.html",
        "results/data_stats/resplit_summary/dashboard.html",


rule app_models:
    """Build all ONNX exports, normalization stats, and the model manifest.

    This is the minimal set of outputs required to run the app (web or desktop)
    with locally served models::

        snakemake app_models --workflow-profile workflow/profiles/local

    The ONNX export directories are built implicitly as dependencies of
    the normalization stats and model manifest rules.
    """
    input:
        *_get_normalization_stats_targets(),
        *_get_model_manifest_target(),



set -euo pipefail

VENV_DIR="$(pwd)/.venv"

DIRENV_SHELL="$(basename -- ${SHELL})"

eval "$(conda shell.${DIRENV_SHELL} hook)"

if [ ! -d "${VENV_DIR}" ]; then
    # Detect platform for pin file selection
    case "$(uname -s)-$(uname -m)" in
        Darwin-arm64) PLATFORM="osx-arm64" ;;
        Linux-x86_64) PLATFORM="linux-64" ;;
        *) echo "Unsupported platform: $(uname -s)-$(uname -m)" && exit 1 ;;
    esac

    PIN_FILE="environment.${PLATFORM}.pin.txt"
    echo "Creating local conda env at ${VENV_DIR} from ${PIN_FILE}..."
    conda create -p "${VENV_DIR}" --file "${PIN_FILE}"

    echo "Installing pip-only packages..."
    conda run -p "${VENV_DIR}" pip install esm==3.2.3
    conda run -p "${VENV_DIR}" pip install --no-deps -e .
fi

echo "Activating local conda env at ${VENV_DIR}..."
conda activate "${VENV_DIR}"

set +euo pipefail
